SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID

# GitHub release update source for in-app "new version available" checks.
# Fork builders can replace this with "<owner>/<repo>".
GITHUB_RELEASE_REPO=YOUR_GITHUB_OWNER/YOUR_GITHUB_REPO
# Optional direct URL overrides (leave empty to auto-build from GITHUB_RELEASE_REPO).
# GITHUB_RELEASE_API_URL=
# GITHUB_RELEASE_PAGE_URL=